# QuantumAtlas example environment file
# These sample values match the current defaults in atlas/server/config.py: ServerConfig

# 反代 / EasyTier 需连入时 SERVER_HOST 可设为 0.0.0.0。
# systemd unit 生成时会把当前 SERVER_HOST/SERVER_PORT 固定写入 ExecStart；
# 修改监听地址或端口后，请重新生成并安装 service 文件。
SERVER_HOST=127.0.0.1
SERVER_PORT=4200
SERVER_DEBUG=false

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Local default is wiki; production/collaboration deployments can point this
# to a separate QuantumAtlas-Wiki checkout, e.g. /srv/quantumatlas-wiki.
WIKI_DIR=wiki
RAW_DIR=raw
DATA_DIR=data

# External base URL for API, share links, and external parsers.
PUBLIC_BASE_URL=
# Optional built-in non-expiring share token for paper assets.
SHARE_ACCESS_TOKEN=
DEFAULT_SHARE_EXPIRES_IN=600
# Server-side audit option: name of the user header injected by your reverse proxy / SSO / API gateway.
# Clients should not set this manually; QuantumAtlas does not use it for authentication or authorization.
USER_HEADER=X-Forwarded-User
# Production guard: require the running checkout to be exactly on v{pyproject version}.
QUANTUMATLAS_REQUIRE_RELEASE_TAG=false

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional MinerU precision extraction API.
# Ingest requests can set {"parser":"mineru"} to parse PDFs via MinerU.
MINERU_API_TOKEN=
MINERU_API_BASE_URL=https://mineru.net
MINERU_MODEL_VERSION=vlm
MINERU_LANGUAGE=ch
MINERU_IS_OCR=false
MINERU_ENABLE_FORMULA=true
MINERU_ENABLE_TABLE=true
MINERU_POLL_INTERVAL=3
MINERU_TIMEOUT=1800
