# QuantumAtlas 环境变量覆盖模板
#
# 复制本文件为 .env，然后只取消注释你明确想覆盖的变量。
# 保持注释时，atlas/server/config.py 会使用代码内置的本地开发默认值。
#
# 不要提交真实 .env。token、API key、公网 URL 都应视为部署环境专属配置或密钥。

# 服务监听地址。位于本机反向代理后时使用 127.0.0.1；只有在明确配置好防火墙和
# 反向代理边界时，才考虑监听 0.0.0.0。
# SERVER_HOST=127.0.0.1
# SERVER_PORT=4200
# SERVER_DEBUG=false

# Neo4j 连接配置。
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# 存储根目录。
# - WIKI_DIR 推荐外置到一个独立 Git checkout（如 ../QuantumAtlas-Wiki），方便多人 PR / review。
# - RAW_DIR 和 DATA_DIR 默认就在仓库内（raw/, data/）；只有在确实需要把
#   论文资产和运行状态从代码仓库里搬出来时才覆盖。
# WIKI_DIR=../QuantumAtlas-Wiki
# RAW_DIR=raw
# DATA_DIR=data

# API、share 链接和外部解析器使用的对外根地址。
# PUBLIC_BASE_URL=https://atlas.example.com

# 可选的常驻 share token，用于 canonical paper assets。
# 只有在明确需要稳定、不过期的 /share/<token>/... URL 时才设置。
# SHARE_ACCESS_TOKEN=<generate-a-long-random-token>

# 通过 POST /api/shares 创建的动态 share token，如果请求未提供 expires_in，
# 会使用这里的 TTL。取消注释即可覆盖代码默认值。
# DEFAULT_SHARE_EXPIRES_IN=600

# 可选的服务端审计用户头，由反向代理、SSO 或 API gateway 注入。
# 留空时不记录用户头；客户端不应手动设置这个头。
# USER_HEADER=X-Token-Subject

# 生产保护：要求当前运行 checkout 恰好位于 v{pyproject version} tag。
# QUANTUMATLAS_REQUIRE_RELEASE_TAG=true

# 可选的本地或服务端 LLM 提取密钥。
# 如果提取流程在 QuantumAtlas 外部处理，或 ingest 使用 --no-extract，请保持未设置。
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# 可选的 MinerU 精准解析 API。
# ingest 请求可设置 {"parser":"mineru"}，通过 MinerU 解析 PDF。
# MINERU_API_TOKEN=
# MINERU_API_BASE_URL=https://mineru.net
# MINERU_MODEL_VERSION=vlm
# MINERU_LANGUAGE=ch
# MINERU_IS_OCR=false
# MINERU_ENABLE_FORMULA=true
# MINERU_ENABLE_TABLE=true
# MINERU_POLL_INTERVAL=3
# MINERU_TIMEOUT=1800
