# ──────────────────────────────────────────────────────────────────────
# QuantumAtlas docker-compose .env template
#
# Copy to .env (gitignored, mode 0600 if you can):
#   cp .env.docker.example .env
#   chmod 0600 .env
#   $EDITOR .env
#
# Then `docker compose up -d`.
#
# Reference docs:
#   * docs/deployment/docker.md            — full setup tutorial
#   * docs/deployment/server-config.md     — every env var qatlasd reads
# ──────────────────────────────────────────────────────────────────────

# ─── Image tag ──────────────────────────────────────────────────────
# Pin a release for prod; `latest` is fine for local eval.
# QATLAS_VERSION=v0.16.0
QATLAS_VERSION=latest

# ─── RustFS root credentials ────────────────────────────────────────
# Used ONLY for the rustfs container itself + once-off bootstrap (mc).
# DO NOT use these as qatlasd's QATLAS_S3_* credentials — mint a
# service account first (see docs/deployment/rustfs.md or
# scripts/rustfs_bootstrap.sh).
RUSTFS_ROOT_ACCESS_KEY=replace-me-root-access
RUSTFS_ROOT_SECRET_KEY=replace-me-with-min-8-character-secret

# ─── qatlasd's S3 service-account credentials ──────────────────────
# After rustfs is up, mint these via:
#   docker run --rm --network=container:qatlas-rustfs minio/mc \
#     mc alias set local http://localhost:9000 <ROOT_ACCESS> <ROOT_SECRET>
#   docker run --rm --network=container:qatlas-rustfs minio/mc \
#     mc admin user svcacct add local <root-user> --name qatlasd
# Then paste the access/secret pair into the two fields below and
# `docker compose up -d qatlasd`.
QATLAS_S3_ACCESS_KEY_ID=replace-me-svcacct-access
QATLAS_S3_SECRET_ACCESS_KEY=replace-me-svcacct-secret

# Public-facing object-storage endpoint (for presigned URLs delivered
# to browsers / external clients). Leave empty when clients reach the
# rustfs container via the same docker network as qatlasd (local
# eval); set when production clients hit a separate HTTPS host.
# QATLAS_S3_PUBLIC_ENDPOINT=https://raw.atlas.example.com

# ─── Neo4j ──────────────────────────────────────────────────────────
# NEO4J_AUTH=neo4j/<this-password> is what the neo4j container reads.
# Min length 8 chars or Neo4j 5 refuses to boot.
NEO4J_PASSWORD=replace-me-strong-password
# JVM heap — see docs/deployment/neo4j.md#hardware-sizing for sizing
# guidance. 1G is fine for the 10k-node scale; bump to 2-4G for
# 100k+ nodes.
NEO4J_HEAP=1G

# ─── GitHub OAuth (required for browser login) ─────────────────────
# Create an OAuth app at https://github.com/settings/developers
# (callback URL = https://<your public domain>/api/oauth2-redirect).
# Fail-closed: if both ALLOWED and ADMIN logins are empty, NOBODY
# can sign in — deliberate "locked by default" posture.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
QATLAS_ALLOWED_GITHUB_LOGINS=your-gh-login
QATLAS_ADMIN_GITHUB_LOGINS=your-gh-login

# ─── Optional: system PAT (breakglass / CI bearer token) ──────────
# Useful for: edge bootstrap, scripts that can't run a browser OAuth
# flow, recovery when PocketBase is sick. Generate via:
#   openssl rand -base64 32
# Min 16 chars or boot fails. Leave empty to disable the feature.
# QATLAS_SYSTEM_PAT=

# Comma-separated scope list, or * for full access. Leave empty
# (== "*") for the common breakglass scenario. See `qatlasd pat
# scopes` for the catalog.
# QATLAS_SYSTEM_PAT_SCOPES=*

# ─── Optional: edge identity (multi-edge audit only) ───────────────
# Folded into the S3 client User-Agent (qatlasd/<version>/<edge>) so
# the rustfs audit trail can tell apart writes from different edges
# at a glance. Cosmetic — never load-bearing for auth.
# QATLAS_EDGE_NAME=local
