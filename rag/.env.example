# qatlas-rag environment template.
#
# Copy this file to `.env` (gitignored) and fill in real values.
# Each role only needs a subset:
#   embed worker  → QATLAS_RAG_EMBED_TOKEN  (auth in)
#   ingester      → QATLAS_RAG_S3_* + QATLAS_RAG_QDRANT_API_KEY + QATLAS_RAG_EMBED_*
#   sidecar       → QATLAS_RAG_QDRANT_* (use the RO key!) + QATLAS_RAG_EMBED_*

# --- Qdrant (1810 docker) ---
QATLAS_RAG_QDRANT_URL=http://10.144.18.10:6334
QATLAS_RAG_QDRANT_HTTP_URL=http://10.144.18.10:6333
# Read-only key for sidecar; read-write for ingester. Generate on 1810
# with `openssl rand -hex 32` and store in `1810:/home/timidly/qatlas-rag/.env`.
QATLAS_RAG_QDRANT_API_KEY=
QATLAS_RAG_QDRANT_COLLECTION=qatlas_papers_v1

# --- Embed worker (Ag-Workstation 5080) ---
QATLAS_RAG_EMBED_URL=http://10.144.18.88:8801
# Shared bearer token; sidecar & ingester send `Authorization: Bearer <this>`.
# Generate with `openssl rand -hex 32`. Different from QDRANT key.
QATLAS_RAG_EMBED_TOKEN=
QATLAS_RAG_EMBED_MODEL=BAAI/bge-m3
QATLAS_RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- RustFS (1810) ---
QATLAS_RAG_S3_ENDPOINT=http://10.144.18.10:9000
QATLAS_RAG_S3_REGION=us-east-1
# Service account `qatlas-rag-ro` (policy: read-only on qatlas-md + qatlas-images).
# NOT the same as qatlasd's rw key.
QATLAS_RAG_S3_ACCESS_KEY=
QATLAS_RAG_S3_SECRET_KEY=
QATLAS_RAG_S3_MD_BUCKET=qatlas-md
QATLAS_RAG_S3_IMAGES_BUCKET=qatlas-images

# --- Local state ---
QATLAS_RAG_MANIFEST_PATH=./manifest.db
