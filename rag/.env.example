# --- Embed worker (跑在 GPU 主机，唯一保留的 Python 进程) ---
#
# 5080 / sm_120 上跑 bge-m3 + bge-reranker-v2-m3。监听 0.0.0.0:8801，
# 等 qatlasd 通过 HTTP 调 /embed 和 /rerank。
#
# 客户端调用时带 `Authorization: Bearer <QATLAS_RAG_EMBED_TOKEN>`，
# /healthz 例外（无 token）。

QATLAS_RAG_EMBED_TOKEN=

# 默认 BAAI/bge-m3；改 fine-tuned checkpoint 直接换 HuggingFace
# repo id 或本地路径。
QATLAS_RAG_EMBED_MODEL=BAAI/bge-m3
QATLAS_RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
