# Caddy reverse proxy example for QuantumAtlas + PocketBase
#
# This replaces caddy-security based auth with pure TLS reverse proxy.
# PocketBase handles all authentication internally.

atlas.example.com {
	# PocketBase admin UI (restrict to admin users via PocketBase's own auth)
	handle_path /pb-admin/* {
		reverse_proxy localhost:8090 {
			transport http {
				read_timeout 360s
			}
		}
	}

	# PocketBase API (OAuth callbacks, custom endpoints)
	handle /api/pb/* {
		uri strip_prefix /api/pb
		reverse_proxy localhost:8090 {
			transport http {
				read_timeout 360s
			}
		}
	}

	# QuantumAtlas FastAPI (everything else)
	handle {
		reverse_proxy localhost:4200 {
			transport http {
				read_timeout 360s
			}
		}
	}
}
