# Vite dev-server overrides. Copy to `.env.development.local` (gitignored
# via *.local) and fill in for your own environment.
#
# All three vars are dev-only — `vite build` ignores `import.meta.env.DEV`
# branches so nothing leaks into production bundles.

# Point at a live qatlasd (local or remote) that vite will reverse-
# proxy /api/*, /_/* (PocketBase admin), and /share/* to. Without this
# the SPA's fetch calls would hit vite's SPA fallback and crash with
# "Unexpected token '<', \"<!doctype \" is not valid JSON".
#
# Examples:
#   VITE_DEV_API_TARGET=http://127.0.0.1:4200        # local qatlasd
#   VITE_DEV_API_TARGET=https://your-qatlas.example  # remote prod / staging
#
# Self-signed certs are accepted (proxy.secure=false in vite.config.ts).
VITE_DEV_API_TARGET=

# Bypass the SPA's PocketBase login screen so UI work doesn't require
# completing GitHub OAuth in this origin. Reads succeed via the proxied
# qatlasd; write endpoints (uploads, PAT mgmt) will still 401
# because no real bearer is sent. Set to 1 to enable.
VITE_DEV_FAKE_AUTH=

# Comma-separated extra Host headers vite will accept (in addition to
# localhost / 127.0.0.1). Needed when previewing the dev server through
# a reverse proxy on a non-loopback hostname/IP — vite 5+ rejects
# unknown Hosts by default.
#
# Example: VITE_DEV_ALLOWED_HOSTS=preview.example.com,10.0.0.5
VITE_DEV_ALLOWED_HOSTS=

# dev-only opt-in: 把 /api/rag/* 单独反代到一个 RAG sidecar（绕开
# VITE_DEV_API_TARGET 指向的远端 qatlasd）。两种典型场景：
#   1. 远端 qatlasd 没设 QATLAS_RAG_SIDECAR_URL — /api/rag/* 404 →
#      SPA 看不到 wiki/search 的 "语义" toggle；
#   2. 想在 dev 时本地 iterate sidecar 行为 / 看真 query trace。
# sidecar 自己监听 /healthz 和 /search（不是 /api/rag/healthz），vite
# 会自动 rewrite ^/api/rag → ''。空 = 不挂这条 proxy，/api/rag/* 仍
# 走 VITE_DEV_API_TARGET。
#   VITE_DEV_RAG_SIDECAR=http://127.0.0.1:8802   # 本机 sidecar
VITE_DEV_RAG_SIDECAR=

# dev-only: a system PAT configured on the VITE_DEV_API_TARGET server
# (its QATLAS_SYSTEM_PAT env). Vite injects it as `Authorization: Bearer
# <PAT>` on proxied /api/* requests so reads succeed now that the backend
# gates all reads behind authGuard. Leave empty to send no bearer (reads
# will 401). Only used in `vite dev`; `vite build` never embeds it.
#   VITE_DEV_API_PAT=<the server's QATLAS_SYSTEM_PAT value>
VITE_DEV_API_PAT=
